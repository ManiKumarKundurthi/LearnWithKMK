<header class="site-header">
  <div class="shell">
    <a href="{{ '/' | url }}" class="site-mark">{{ site.title }}</a>
    <nav class="site-nav">
      {% for item in site.nav %}
        <a href="{{ item.url | url }}" {% if page.url == item.url %}aria-current="page"{% endif %}>{{ item.text }}</a>
      {% endfor %}
    </nav>
  </div>
</header>
